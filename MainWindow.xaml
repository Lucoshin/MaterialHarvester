<Window x:Class="VideoToMaterial.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Ui.WindowTitle}"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
    <Grid Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="DependencyBanner"
                Grid.Row="0"
                Visibility="Collapsed"
                Background="#401E1B22"
                BorderBrush="#7F9F1239"
                BorderThickness="0,0,0,1"
                Padding="16,10"
                Panel.ZIndex="50">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="!" Foreground="#FB7185" FontWeight="Bold" FontSize="14" Margin="0,0,10,0" />
                    <TextBlock Text="{DynamicResource Ui.DependencyMissing}"
                               Foreground="#FDA4AF"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource SecondaryButton}"
                        Background="#4C881337"
                        BorderBrush="#7FFECDD3"
                        Foreground="#FDA4AF"
                        Padding="12,5"
                        FontSize="11"
                        Content="{DynamicResource Ui.OpenDependencyDir}"
                        Click="FixDependency_Click" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="SourceRow" Height="5*" MinHeight="180" />
                <RowDefinition Height="8" />
                <RowDefinition x:Name="ConfigRow" Height="2*" MinHeight="165" />
                <RowDefinition Height="8" />
                <RowDefinition x:Name="LogRow" Height="1.35*" MinHeight="110" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,14" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource EmeraldBrush}" Margin="0,0,10,0" />
                    <TextBlock x:Name="QueueStatus"
                               Text="{DynamicResource Ui.QueueEmpty}"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Ui.Language}"
                               FontSize="11"
                               Foreground="{StaticResource DimTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox x:Name="LanguageCombo"
                              Width="118"
                              Margin="0,0,10,0"
                              SelectedValuePath="Tag"
                              SelectionChanged="LanguageCombo_SelectionChanged">
                        <ComboBoxItem Tag="Auto" Content="{DynamicResource Ui.LanguageAuto}" />
                        <ComboBoxItem Tag="Chinese" Content="{DynamicResource Ui.LanguageZh}" />
                        <ComboBoxItem Tag="English" Content="{DynamicResource Ui.LanguageEn}" />
                    </ComboBox>
                    <Button x:Name="BtnToggleLog"
                            Style="{StaticResource SecondaryButton}"
                            Content="{DynamicResource Ui.HideLog}"
                            MinWidth="92"
                            Margin="0,0,10,0"
                            Click="ToggleLog_Click" />
                    <Button x:Name="BtnReset"
                            Style="{StaticResource GhostDangerButton}"
                            Content="{DynamicResource Ui.ResetQueue}"
                            MinWidth="112"
                            Margin="0,0,10,0"
                            Click="Reset_Click" />
                    <Button x:Name="BtnStart"
                            Style="{StaticResource PrimaryButton}"
                            Content="{DynamicResource Ui.StartBatch}"
                            MinWidth="210"
                            Height="46"
                            IsEnabled="False"
                            Click="Start_Click" />
                </StackPanel>
            </DockPanel>

            <Border x:Name="DropZone"
                    Grid.Row="1"
                    CornerRadius="14"
                    BorderThickness="2"
                    BorderBrush="#3F3F46"
                    Background="#7F18181B"
                    Padding="32"
                    Cursor="Hand"
                    AllowDrop="True"
                    DragEnter="DropZone_DragEnter"
                    Drop="DropZone_Drop"
                    MouseLeftButtonUp="DropZone_MouseLeftButtonUp">
                <Grid>
                    <StackPanel x:Name="EmptySourcePanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <Viewbox Width="72" Height="72" Margin="0,0,0,20">
                            <Grid Width="64" Height="64">
                                <Path Stroke="#A1A1AA" StrokeThickness="2.2" Fill="Transparent" StrokeLineJoin="Round"
                                      Data="M10,22 L10,50 L54,50 L54,24 L32,24 L27,16 L14,16 C11.8,16 10,17.8 10,20 Z" />
                                <Path Stroke="#71717A" StrokeThickness="1.4" Fill="Transparent"
                                      Data="M18,31 L46,31 M18,38 L46,38 M18,45 L34,45" />
                                <Path Stroke="#10B981" StrokeThickness="1.8" Fill="Transparent"
                                      Data="M10,25 L54,25" Opacity="0.75" />
                            </Grid>
                        </Viewbox>
                        <TextBlock x:Name="DropTitle"
                                   Text="{DynamicResource Ui.DropTitleEmpty}"
                                   Foreground="#E4E4E7"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{DynamicResource Ui.DropSubtitle}"
                                   Foreground="#A1A1AA"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0" />
                        <Button Style="{StaticResource LinkButton}"
                                Margin="0,14,0,0"
                                HorizontalAlignment="Center"
                                Click="AddLink_Click">
                            <TextBlock Text="{DynamicResource Ui.AddLink}" FontSize="13" TextDecorations="Underline" />
                        </Button>
                    </StackPanel>
                    <ScrollViewer x:Name="QueueScroll"
                                  Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="QueuePreview">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="QueueCard"
                                            Width="176"
                                            Height="150"
                                            Margin="10"
                                            Padding="10"
                                            CornerRadius="10"
                                            Background="#1A1A1D"
                                            BorderBrush="#2E2E33"
                                            BorderThickness="1">
                                        <Grid>
                                            <StackPanel>
                                                <Border Height="88"
                                                        CornerRadius="8"
                                                        Background="#26262A"
                                                        BorderBrush="#3F3F46"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid x:Name="ThumbnailPlaceholder">
                                                            <Rectangle Fill="#18181B" Margin="12,14,12,14" RadiusX="4" RadiusY="4" />
                                                            <TextBlock Text="{DynamicResource Ui.PreviewLoading}"
                                                                       Foreground="#6EE7B7"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="7,10,0,10">
                                                                <Rectangle Width="8" Height="8" Fill="#E4E4E7" RadiusX="2" RadiusY="2" Margin="0,0,0,8" />
                                                                <Rectangle Width="8" Height="8" Fill="#E4E4E7" RadiusX="2" RadiusY="2" Margin="0,0,0,8" />
                                                                <Rectangle Width="8" Height="8" Fill="#E4E4E7" RadiusX="2" RadiusY="2" />
                                                            </StackPanel>
                                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Margin="0,10,7,10">
                                                                <Rectangle Width="8" Height="8" Fill="#E4E4E7" RadiusX="2" RadiusY="2" Margin="0,0,0,8" />
                                                                <Rectangle Width="8" Height="8" Fill="#E4E4E7" RadiusX="2" RadiusY="2" Margin="0,0,0,8" />
                                                                <Rectangle Width="8" Height="8" Fill="#E4E4E7" RadiusX="2" RadiusY="2" />
                                                            </StackPanel>
                                                        </Grid>
                                                        <Image Source="{Binding Thumbnail}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                                        <Border VerticalAlignment="Bottom"
                                                                Background="#99000000"
                                                                Padding="6,2">
                                                            <TextBlock Text="{Binding Extension}"
                                                                       Foreground="#D4D4D8"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#F4F4F5"
                                                           FontSize="12"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="38"
                                                           Margin="0,9,0,0" />
                                            </StackPanel>

                                            <Button x:Name="RemoveVideoButton"
                                                    Width="26"
                                                    Height="26"
                                                    Padding="0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,-7,-7,0"
                                                    Content="×"
                                                    ToolTip="{DynamicResource Ui.RemoveVideo}"
                                                    Click="RemoveVideo_Click"
                                                    Background="#E11D48"
                                                    BorderBrush="#FDA4AF"
                                                    Foreground="White"
                                                    FontSize="18"
                                                    FontWeight="SemiBold"
                                                    Cursor="Hand"
                                                    Opacity="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Root"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="13">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"
                                                                              Margin="0,-2,0,0" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#F43F5E" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="QueueCard" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RemoveVideoButton" Property="Opacity" Value="1" />
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="2"
                          Height="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#121214"
                          ShowsPreview="True"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Row="3"
                    CornerRadius="14"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="#27272A"
                    BorderThickness="1"
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*" />
                        <ColumnDefinition Width="6*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,24,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{DynamicResource Ui.OutputLocation}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,0,0,8" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtOutputDir"
                                     Grid.Column="0"
                                     Text="{DynamicResource Ui.DefaultOutput}"
                                     IsReadOnly="True"
                                     Margin="0,0,10,0" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="{DynamicResource Ui.Browse}"
                                    Click="BrowseOutput_Click" />
                            <Button x:Name="BtnOpenDir"
                                    Grid.Column="2"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="{DynamicResource Ui.Open}"
                                    Margin="8,0,0,0"
                                    Visibility="Collapsed"
                                    Click="OpenOutput_Click" />
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Ui.OutputRule}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,0,0,7" />
                                <Border Background="#18181B" BorderBrush="#2E2E33" BorderThickness="1" CornerRadius="8" Padding="12,9">
                                    <TextBlock x:Name="PathHint" Text="{DynamicResource Ui.PathHint}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource Ui.Audio}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,0,0,7" />
                                <Border Background="#18181B" BorderBrush="#2E2E33" BorderThickness="1" CornerRadius="8" Padding="12,9">
                                    <CheckBox x:Name="ChkMute" Content="{DynamicResource Ui.Mute}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,14">
                            <TextBlock Text="{DynamicResource Ui.SplitMode}"
                                       FontSize="11"
                                       Foreground="{StaticResource DimTextBrush}"
                                       Margin="0,0,0,7"
                                       ToolTip="{DynamicResource Ui.SplitModeTooltip}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="SmartModeRadio"
                                             Grid.Column="0"
                                             GroupName="SplitMode"
                                             Content="{DynamicResource Ui.SmartScene}"
                                             IsChecked="True"
                                             Style="{StaticResource ModeRadioButton}"
                                             ToolTip="{DynamicResource Ui.SmartTooltip}"
                                             Checked="SplitMode_Checked" />
                                <RadioButton x:Name="FixedModeRadio"
                                             Grid.Column="2"
                                             GroupName="SplitMode"
                                             Content="{DynamicResource Ui.FixedDuration}"
                                             Style="{StaticResource ModeRadioButton}"
                                             ToolTip="{DynamicResource Ui.FixedTooltip}"
                                             Checked="SplitMode_Checked" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock x:Name="SensitivityLabel"
                                       Text="{DynamicResource Ui.Sensitivity}"
                                       FontSize="11"
                                       Foreground="{StaticResource DimTextBrush}"
                                       Margin="0,0,0,7"
                                       ToolTip="{DynamicResource Ui.SensitivityTooltip}" />
                            <Slider x:Name="SensitivitySlider"
                                    Minimum="0.01"
                                    Maximum="1"
                                    Value="0.75"
                                    TickFrequency="0.01"
                                    IsSnapToTickEnabled="True"
                                    ToolTip="{DynamicResource Ui.SensitivitySliderTooltip}"
                                    ValueChanged="SensitivitySlider_ValueChanged" />
                            <TextBlock x:Name="SensitivityValue" Text="0.75" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="DurationLabel" Text="{DynamicResource Ui.DurationLabel}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,0,0,7" />
                                    <TextBox x:Name="TxtDuration" Text="10" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{DynamicResource Ui.Threads}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,0,0,7" />
                                    <TextBox x:Name="TxtThreads" Text="3" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,14,0,0">
                            <TextBlock Text="{DynamicResource Ui.Detector}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,0,0,7" />
                            <ComboBox x:Name="DetectorCombo"
                                      SelectedIndex="0"
                                      Width="360"
                                      HorizontalAlignment="Left">
                                <ComboBoxItem Content="{DynamicResource Ui.ContentDetector}" />
                                <ComboBoxItem Content="{DynamicResource Ui.AdaptiveDetector}" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter x:Name="LogSplitter"
                          Grid.Row="4"
                          Height="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#121214"
                          ShowsPreview="True"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <Border x:Name="LogDrawer"
                    Grid.Row="5"
                    Background="#151518"
                    BorderBrush="#27272A"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Ui.RunLog}" DockPanel.Dock="Left" Foreground="#A1A1AA" FontSize="11" FontWeight="SemiBold" />
                        <ProgressBar x:Name="Progress"
                                     DockPanel.Dock="Right"
                                     Width="260"
                                     Height="6"
                                     Minimum="0"
                                     Maximum="100"
                                     Visibility="Collapsed"
                                     Foreground="{StaticResource EmeraldBrush}"
                                     Background="#27272A" />
                    </DockPanel>
                    <TextBox x:Name="TxtLog"
                             Grid.Row="1"
                             Background="#151518"
                             BorderThickness="0"
                             Foreground="#A1A1AA"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="11"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             Padding="0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

